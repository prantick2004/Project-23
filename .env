# ─── Application ─────────────────────────────────────────
APP_NAME="Project-23"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY="project23-super-secret-key-change-this-in-production-2024"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=project23_db
DATABASE_USER=project23_user
DATABASE_PASSWORD=project23_pass
DATABASE_URL=postgresql+asyncpg://project23_user:project23_pass@localhost:5432/project23_db

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Storage ──────────────────────────────────────────────
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=10

# ─── Face Recognition ─────────────────────────────────────
FACE_RECOGNITION_TOLERANCE=0.55
FACE_RECOGNITION_MODEL=hog
ENCODING_CACHE_SIZE=1000

# ─── Attendance ───────────────────────────────────────────
LATE_THRESHOLD_MINUTES=15
ATTENDANCE_COOLDOWN_MINUTES=5

# ─── Alerts ───────────────────────────────────────────────
EMAIL_ENABLED=False
SMS_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=""
EMAIL_PASSWORD=""

# ─── Evidence ─────────────────────────────────────────────
EVIDENCE_RETENTION_DAYS=90
